    "lint:css": "stylelint \"ffc-academy/assets/scss/**/*.scss\"",
    "lint:php": "\"/Users/elgusto/Library/Application Support/Local/lightning-services/php-8.2.29+0/bin/darwin-arm64/bin/php\" composer.phar lint:php",
    "fix:php": "\"/Users/elgusto/Library/Application Support/Local/lightning-services/php-8.2.29+0/bin/darwin-arm64/bin/php\" composer.phar fix:php",
    "lint": "npm run lint:css && npm run lint:php"
  },
  "devDependencies": {
    "sass": "1.69.5",
    "stylelint": "16.6.1",
    "stylelint-config-standard-scss": "13.1.0"
